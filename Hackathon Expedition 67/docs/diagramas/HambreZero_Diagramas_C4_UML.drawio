  <diagram id="c4-container" name="C4 - 2. Contenedores">
    <mxGraphModel dx="1310" dy="848" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="ct-title" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=16;" value="&lt;b&gt;C4 Nivel 2 — Diagrama de Contenedores&lt;/b&gt;&lt;br&gt;HambreZero System Boundary" vertex="1">
          <mxGeometry height="50" width="440" x="480" y="20" as="geometry" />
        </mxCell>
        <mxCell id="ct-boundary" parent="1" style="shape=swimlane;whiteSpace=wrap;html=1;dashed=1;startSize=30;fillColor=none;strokeColor=#116644;strokeWidth=2;fontSize=12;" value="&lt;b&gt;Sistema HambreZero&lt;/b&gt; [System Boundary]" vertex="1">
          <mxGeometry height="700" width="1100" x="200" y="80" as="geometry" />
        </mxCell>
        <mxCell id="ct-spa" parent="ct-boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#22976e;fontColor=#ffffff;strokeColor=#177151;align=center;fontSize=10;" value="&lt;b&gt;Web Application (SPA)&lt;/b&gt;&lt;br&gt;[Container: HTML5 / CSS3 / JavaScript ES6+]&lt;br&gt;&lt;br&gt;10 páginas estáticas con UI interactiva, animaciones, sistema de componentes CSS custom properties, modales, toasts. Incluye Leaflet.js para mapas." vertex="1">
          <mxGeometry height="100" width="460" x="50" y="60" as="geometry" />
        </mxCell>
        <mxCell id="ct-css" parent="ct-boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#22976e;fontColor=#ffffff;strokeColor=#177151;align=center;fontSize=10;" value="&lt;b&gt;Design System&lt;/b&gt;&lt;br&gt;[Container: CSS / Custom Properties]&lt;br&gt;&lt;br&gt;styles.css: Design tokens, componentes reutilizables (buttons, cards, badges, modals, progress bars), responsive." vertex="1">
          <mxGeometry height="100" width="460" x="610" y="60" as="geometry" />
        </mxCell>
        <mxCell id="ct-appjs" parent="ct-boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#3182ce;fontColor=#ffffff;strokeColor=#2563a8;align=center;fontSize=10;" value="&lt;b&gt;app.js — Core Logic&lt;/b&gt;&lt;br&gt;[Container: JavaScript]&lt;br&gt;&lt;br&gt;Estado global (AppState), datos mock, sistema Toast/Modal, contadores animados, scroll reveal, render de bulletin cards y rank cards." vertex="1">
          <mxGeometry height="120" width="300" x="50" y="220" as="geometry" />
        </mxCell>
        <mxCell id="ct-authjs" parent="ct-boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#3182ce;fontColor=#ffffff;strokeColor=#2563a8;align=center;fontSize=10;" value="&lt;b&gt;auth.js — Autenticación&lt;/b&gt;&lt;br&gt;[Container: JavaScript]&lt;br&gt;&lt;br&gt;Login/Registro mock con localStorage, formularios dinámicos por tipo de cuenta, validación de campos, toggle password." vertex="1">
          <mxGeometry height="120" width="300" x="400" y="240" as="geometry" />
        </mxCell>
        <mxCell id="ct-mapjs" parent="ct-boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#3182ce;fontColor=#ffffff;strokeColor=#2563a8;align=center;fontSize=10;" value="&lt;b&gt;map.js — Mapa Interactivo&lt;/b&gt;&lt;br&gt;[Container: JavaScript + Leaflet.js]&lt;br&gt;&lt;br&gt;Inicializa Leaflet, marcadores de zonas e instituciones, popups interactivos, panel lateral, capas toggleables, búsqueda." vertex="1">
          <mxGeometry height="120" width="300" x="750" y="220" as="geometry" />
        </mxCell>
        <mxCell id="ct-ls" parent="ct-boundary" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#1e293b;fontColor=#ffffff;strokeColor=#0f172a;align=center;fontSize=10;" value="&lt;b&gt;localStorage&lt;/b&gt;&lt;br&gt;[Container: Browser Storage]&lt;br&gt;&lt;br&gt;Persiste sesión de usuario (hz_user) con tipo de cuenta y datos básicos." vertex="1">
          <mxGeometry height="130" width="200" x="80" y="430" as="geometry" />
        </mxCell>
        <mxCell id="ct-api" parent="ct-boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#64748b;fontColor=#ffffff;strokeColor=#475569;align=center;fontSize=10;dashed=1;" value="&lt;b&gt;API Backend&lt;/b&gt;&lt;br&gt;[Container: Node.js / Express]&lt;br&gt;&lt;i&gt;(Planificado — Sprint futuro)&lt;/i&gt;&lt;br&gt;&lt;br&gt;REST API para auth, CRUD tablones, donaciones, ranking." vertex="1">
          <mxGeometry height="120" width="280" x="390" y="430" as="geometry" />
        </mxCell>
        <mxCell id="ct-db" parent="ct-boundary" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#64748b;fontColor=#ffffff;strokeColor=#475569;align=center;fontSize=10;dashed=1;" value="&lt;b&gt;Base de Datos&lt;/b&gt;&lt;br&gt;[Container: PostgreSQL]&lt;br&gt;&lt;i&gt;(Planificado)&lt;/i&gt;&lt;br&gt;&lt;br&gt;Usuarios, donaciones, tablones, certificados." vertex="1">
          <mxGeometry height="130" width="200" x="770" y="430" as="geometry" />
        </mxCell>
        <mxCell id="ct-redis" parent="ct-boundary" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#cc0000;fontColor=#ffffff;strokeColor=#990000;align=center;fontSize=10;dashed=1;" value="&lt;b&gt;Cache Ranking&lt;/b&gt;&lt;br&gt;[Container: Redis]&lt;br&gt;&lt;i&gt;(Planificado)&lt;/i&gt;" vertex="1">
